# ============================================================================
# Proxy settings for building lite-nvr
#
# These env vars are read by:
#   - ureq (sherpa-onnx-sys build.rs: prebuilt lib download)
#   - ureq (rszlm-sys build.rs: prebuilt ZLM release download -- currently
#     does NOT read proxy; see note below)
#   - git clone (ZLMediaKit / libsrtp source builds)
#   - scripts/download_sherpa_onnx_libs.sh
#   - scripts/download_asr_models.sh
#   - cargo itself (if CARGO_HTTP_PROXY is set)
#
# Usage:
#   1. Copy this file to .env:  cp .env.example .env
#   2. Edit the values below for your proxy
#   3. Source before building:  set -a && source .env && set +a
#      Or use:  export $(grep -v '^#' .env | xargs)
#
# NOTE: use HTTP proxy, NOT SOCKS5 -- ureq does not ship the socks-proxy
# feature and will fail with "SOCKS feature disabled".
# ============================================================================

# --- HTTP(S) proxy (used by ureq, curl, wget, git, download scripts) ---
HTTP_PROXY=http://127.0.0.1:7897
HTTPS_PROXY=http://127.0.0.1:7897

# Hosts / CIDRs that should bypass the proxy
NO_PROXY=localhost,127.0.0.1,::1,.local

# --- Cargo proxy (optional: if cargo itself needs to go through proxy) ---
# CARGO_HTTP_PROXY=http://127.0.0.1:7897
# CARGO_HTTPS_PROXY=http://127.0.0.1:7897

# --- Git proxy (alternative to setting git config) ---
# GIT_PROXY_COMMAND=connect -H 127.0.0.1:7897 %h %p

# --- NOTE: rszlm-sys prebuilt download ---
# rszlm-sys uses ureq::get() WITHOUT try_proxy_from_env(), so it ignores
# the HTTP_PROXY / HTTPS_PROXY vars above. Workarounds:
#   a) Use a system-wide transparent proxy / VPN / TUN mode
#   b) Set ZLM_BUILD_FROM_SOURCE=1 to build from source (uses git clone,
#      which does respect proxy settings)
#   c) Pre-download the prebuilt archive and point ZLM_DIR at it
#   d) Use ZLM_GIT_ZONE=gitee to clone from the gitee mirror (may be
#      faster / unblocked in mainland China)
